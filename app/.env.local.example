# DeepSeek API key（用于 P6 AI 增强：mainTheme + oneLiner + narrative 重写）
#
# 使用方法：
#   1. 复制本文件为 .env.local： cp .env.local.example .env.local
#   2. 把下面这行的 sk-xxx 换成你的真实 key
#   3. 重启 vite dev server: npm run dev
#
# 安全提示：
#   - .env.local 已被 .gitignore 默认忽略，不会被提交
#   - 千万不要把真实 key 写进 .env.example 提交到仓库
#   - 浏览器端会暴露这个 key（Vite 的 VITE_ 前缀变量会注入到客户端 bundle）
#     生产环境应该改为后端代理调用，前端只调本地 API
#
VITE_DEEPSEEK_API_KEY=sk-xxx
